# Copie ce fichier en `.env` et remplis les valeurs.
# Le fichier `.env` ne doit PAS être commité sur GitHub.
#
# 1. Crée ton app sur https://dev.twitch.tv/console/apps
# 2. Ajoute l'URL de redirection OAuth dans la console Twitch :
#    - http://localhost:23400/api/auth/twitch/callback
#    Twitch peut exiger HTTPS selon ton app/compte; dans ce cas utilise
#    une URL HTTPS déjà supportée par ton app et reporte-la ci-dessous.
# 3. Type : Publique / Catégorie : Application
# 4. Copie le Client ID et le Client Secret ci-dessous

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optionnel (laisser vide pour les valeurs par défaut ci-dessus)
# TWITCH_REDIRECT_URI=http://localhost:23400/api/auth/twitch/callback
# TWITCH_REDIRECT_URI_IOS=http://localhost:23400/api/auth/twitch/callback
