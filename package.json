{
  "name": "nosubvod-ios",
  "version": "0.3.7",
  "description": "NoSubVOD iOS client with embedded Rust backend",
  "author": "Theorhd",
  "scripts": {
    "dev": "concurrently \"npm run dev:portal:https\" \"tauri dev\"",
    "dev:portal": "vite -c src/portal/vite.config.ts --force",
    "dev:portal:https": "vite -c src/portal/vite.config.ts --force",
    "preview:portal": "vite preview -c src/portal/vite.config.ts",
    "tauri": "tauri",
    "ios:init": "tauri ios init",
    "ios:dev": "tauri ios dev",
    "ios:build": "tauri ios build",
    "build": "npm run build:portal && tauri build",
    "build:portal": "vite build -c src/portal/vite.config.ts",
    "build:debug": "npm run build:portal && tauri build --debug",
    "build:ci": "npm run build:portal && tauri build --no-bundle",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "type-check": "tsc -p src/portal/tsconfig.json",
    "check": "npm run lint && npm run type-check"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@vidstack/react": "^1.12.13",
    "hls.js": "^1.6.15",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tauri-plugin-secure-storage": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  }
}
